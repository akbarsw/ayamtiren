# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Supabase / Neon / Railway / self-hosted)
DATABASE_URL="postgresql://user:password@localhost:5432/routerai"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# ─── LLM Provider API Keys ────────────────────────────────────────────────────
# Add the providers you want to use. Unused providers are skipped in routing.
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."
GOOGLE_API_KEY="AIza..."
